# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-key-here
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# Azure Cosmos DB
COSMOS_ENDPOINT=https://your-account.documents.azure.com:443/
COSMOS_KEY=your-key-here
COSMOS_DATABASE=neurofocus

# Azure AI Content Safety
# Optional — app runs without it (screening disabled, warning logged)
CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=your-key-here

# Azure Blob Storage
# Optional — blob archival skipped if not set, document extraction still works
BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-account;AccountKey=your-key;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=documents

# Azure AI Document Intelligence
# Required for /api/upload — endpoint returns 503 without this
DOC_INTELLIGENCE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
DOC_INTELLIGENCE_KEY=your-key-here

# Azure Monitor / Application Insights
# Optional — telemetry and custom events are skipped if not set
APP_INSIGHTS_CONNECTION_STRING=InstrumentationKey=your-key;IngestionEndpoint=https://your-region.in.applicationinsights.azure.com/

# App
ALLOWED_ORIGINS=http://localhost:5173
